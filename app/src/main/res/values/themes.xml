<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.BitcoinDashboard" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Bitcoin Dark Theme -->
        <item name="colorPrimary">#f7931a</item>
        <item name="colorPrimaryVariant">#d4700d</item>
        <item name="colorOnPrimary">#1a0800</item>
        <item name="colorSecondary">#11e88c</item>
        <item name="colorOnSecondary">#070a0f</item>
        <item name="android:colorBackground">#070a0f</item>
        <item name="colorSurface">#0c1119</item>
        <item name="colorOnSurface">#dde4f0</item>

        <!-- Statusbar & Navigationsbar -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">#070a0f</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>

        <!-- Vollbild -->
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowContentOverlay">@null</item>

        <!-- Hardware Acceleration -->
        <item name="android:hardwareAccelerated">true</item>
    </style>
</resources>
