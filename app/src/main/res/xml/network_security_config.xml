<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Explizit erlaubte HTTPS-Domains für die App -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">api.binance.com</domain>
        <domain includeSubdomains="true">api.alternative.me</domain>
        <domain includeSubdomains="true">api.coingecko.com</domain>
        <domain includeSubdomains="true">blocktrainer.de</domain>
        <domain includeSubdomains="true">api.allorigins.win</domain>
        <domain includeSubdomains="true">corsproxy.io</domain>
        <domain includeSubdomains="true">query1.finance.yahoo.com</domain>
        <domain includeSubdomains="true">query2.finance.yahoo.com</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>
</network-security-config>
